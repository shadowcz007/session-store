{
  "name": "@claude-code-local/session-store",
  "version": "0.1.0",
  "description": "Zero-dependency read-only scanner for Claude Code session transcripts. Pure ESM, ships JSON Schema for offline analyzers.",
  "type": "module",
  "license": "MIT",
  "author": "shadowcz007 <chizhiwei007@163.com>",
  "homepage": "https://github.com/shadowcz007/session-store",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shadowcz007/session-store.git"
  },
  "bugs": {
    "url": "https://github.com/shadowcz007/session-store/issues"
  },
  "keywords": [
    "claude-code",
    "transcript",
    "jsonl",
    "session-store",
    "read-only",
    "esm"
  ],
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema": "./schema/index.json",
    "./schema/*.json": "./schema/*.json",
    "./cli": "./dist/cli/smoke.js"
  },
  "bin": {
    "session-store-smoke": "./dist/cli/smoke.js"
  },
  "files": [
    "dist",
    "schema",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "lint": "tsc -p tsconfig.json --noEmit",
    "validate:schema": "bun run scripts/validate-schemas.ts",
    "example:web": "bun run examples/typescript/web-browser.ts",
    "example:dump": "bun run examples/typescript/dump-all-sessions.ts",
    "example:python": "python3 examples/python/analyze_sessions.py"
  },
  "peerDependencies": {},
  "dependencies": {},
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "ajv": "^8.18.0",
    "typescript": "^5.6.0"
  }
}
